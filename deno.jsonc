{
	"tasks": {
		"main": "deno run -A main.ts",
		"compile": "deno compile -A main.ts",
		"compile:win": "deno compile -A --target=x86_64-pc-windows-msvc main.ts"
	},
	"fmt": {
		"lineWidth": 900,
		"semiColons": false,
		"singleQuote": true,
		"useTabs": true
	},
	"imports": {
		"@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0",
		"@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0"
	}
}
